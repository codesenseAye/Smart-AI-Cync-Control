{
  "name": "smart-ai-cync-control-app",
  "version": "1.0.0",
  "description": "Voice-controlled smart light manager",
  "author": "Daniel W",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && node scripts/build-renderer.js && node scripts/copy-static.js",
    "build:server": "node scripts/bundle-server.js",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "watch": "tsc -w & node scripts/build-renderer.js",
    "pack": "npm run build && npm run build:server && electron-builder --dir",
    "release": "npm run build && npm run build:server && electron-builder"
  },
  "build": {
    "appId": "com.smartcync.control",
    "productName": "Smart AI Cync Control",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/server",
        "to": "server"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "assets/smart-cync-ai-control-logo.png"
    },
    "portable": {
      "artifactName": "${productName}.exe"
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
