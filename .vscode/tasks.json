{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "app:build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/app"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "app:build:release",
      "type": "shell",
      "command": "npm run release",
      "options": {
        "cwd": "${workspaceFolder}/app"
      },
      "group": "build",
      "dependsOn": ["server:build"],
      "problemMatcher": []
    },
    {
      "label": "server:build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    }
  ]
}
